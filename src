class IdentityEngine:
    def __init__(self):
        self.users = {}
        self.roles = {}
        self.scopes = {}

    def register_user(self, user_id, attributes=None):
        if attributes is None:
            attributes = {}
        self.users[user_id] = attributes
        return True

    def assign_role(self, user_id, role_name):
        if user_id not in self.users:
            return False
        if role_name not in self.roles:
            self.roles[role_name] = []
        if user_id not in self.roles[role_name]:
            self.roles[role_name].append(user_id)
        return True

    def define_scope(self, scope_name, permissions=None):
        if permissions is None:
            permissions = []
        self.scopes[scope_name] = permissions
        return True

    def user_has_permission(self, user_id, permission):
        for role, users in self.roles.items():
            if user_id in users:
                if permission in self.scopes.get(role, []):
                    return True
        return False
